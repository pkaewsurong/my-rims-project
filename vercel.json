{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": "config/**"
    }
  },
  "routes": [
    {
      "src": "/public/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|pdf|txt|zip|doc|docx|xls|xlsx|ppt|pptx))$",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
