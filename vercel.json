{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0",
      "memory": 512,
      "maxDuration": 30,
      "includeFiles": "{config/**,includes/**,src/**,views/**,vendor/**,public/**}"
    }
  },
  "headers": [
    {
      "source": "/public/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/public/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|pdf|txt|zip|doc|docx|xls|xlsx|ppt|pptx))$",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
